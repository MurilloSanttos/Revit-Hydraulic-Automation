    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Id": "n0500000-0005-4a00-b000-000000000005",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        { "Id": "p0500000-0005-4c00-b000-000000000001", "Name": "IN[0]", "Description": "fixturePoints", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0500000-0005-4c00-b000-000000000002", "Name": "IN[1]", "Description": "feedPoint", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0500000-0005-4c00-b000-000000000003", "Name": "IN[2]", "Description": "fixtureIds", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0500000-0005-4c00-b000-000000000004", "Name": "IN[3]", "Description": "offsetZ", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p0500000-0005-4b00-b000-000000000001", "Name": "OUT", "Description": "ordered data", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script.",
      "Code": "import clr\nclr.AddReference('ProtoGeometry')\nfrom Autodesk.DesignScript.Geometry import Point as DSPoint, Line as DSLine, Vector as DSVector\nimport math\n\nfix_pts = IN[0] if isinstance(IN[0], list) else [IN[0]]\nfeed_pt = IN[1]\nfix_ids = IN[2] if isinstance(IN[2], list) else [IN[2]]\noffset_z = float(IN[3])\n\nfx = feed_pt.X\nfy = feed_pt.Y\n\npaired = []\nfor i, pt in enumerate(fix_pts):\n    try:\n        dx = pt.X - fx\n        dy = pt.Y - fy\n        dist = math.sqrt(dx*dx + dy*dy)\n        paired.append((i, pt, dist, fix_ids[i]))\n    except:\n        continue\n\npaired.sort(key=lambda x: x[2])\n\nordered_pts = []\nordered_ids = []\nfor item in paired:\n    ordered_pts.append(DSPoint.ByCoordinates(item[1].X, item[1].Y, offset_z))\n    ordered_ids.append(item[3])\n\nfeed_hz = DSPoint.ByCoordinates(fx, fy, offset_z)\n\nstart_pts = []\nend_pts = []\nlines = []\n\nprev = feed_hz\nfor pt in ordered_pts:\n    start_pts.append(prev)\n    end_pts.append(pt)\n    try:\n        ln = DSLine.ByStartPointEndPoint(prev, pt)\n        lines.append(ln)\n    except:\n        lines.append(None)\n    prev = pt\n\nOUT = [ordered_pts, ordered_ids, start_pts, end_pts, lines, feed_hz]",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "n0600000-0006-4a00-b000-000000000006",
