    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "n0900000-0009-4a00-a000-000000000009",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        { "Id": "p0900000-0009-4c00-a000-000000000001", "Name": "statuses", "Description": "statuses", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p0900000-0009-4b00-a000-000000000001", "Name": "", "Description": "isOk", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0900000-0009-4b00-a000-000000000002", "Name": "", "Description": "colors", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Allows DesignScript code to be authored directly",
      "Code": "isOk = List.Map(statuses, Function(s) { return s == \"OK\"; });\ngreen = Color.ByARGB(255, 0, 200, 0);\nred = Color.ByARGB(255, 255, 50, 50);\nyellow = Color.ByARGB(255, 255, 200, 0);\ncolors = List.Map(statuses, Function(s) {\n    return s == \"OK\" ? green : (s == \"SEM_PAREDE\" ? yellow : red);\n});"
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "n1000000-0010-4a00-a000-000000000010",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        { "Id": "p1000000-0010-4c00-a000-000000000001", "Name": "ids", "Description": "ids", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p1000000-0010-4c00-a000-000000000002", "Name": "dists", "Description": "dists", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p1000000-0010-4c00-a000-000000000003", "Name": "offsets", "Description": "offsets", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p1000000-0010-4c00-a000-000000000004", "Name": "statuses", "Description": "statuses", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p1000000-0010-4b00-a000-000000000001", "Name": "", "Description": "table", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Allows DesignScript code to be authored directly",
      "Code": "headers = {\"ElementId\", \"Dist.Real\", \"Offset Esp.\", \"Status\"};\nrows = List.Transpose({ids, dists, offsets, statuses});\ntable = List.AddItemToFront(headers, rows);"
    },
