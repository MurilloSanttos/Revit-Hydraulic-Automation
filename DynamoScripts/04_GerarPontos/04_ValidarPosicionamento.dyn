    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Id": "n0700000-0007-4a00-a000-000000000007",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        { "Id": "p0700000-0007-4c00-a000-000000000001", "Name": "IN[0]", "Description": "elements", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0700000-0007-4c00-a000-000000000002", "Name": "IN[1]", "Description": "walls", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0700000-0007-4c00-a000-000000000003", "Name": "IN[2]", "Description": "expectedOffsets", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0700000-0007-4c00-a000-000000000004", "Name": "IN[3]", "Description": "tolerance", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p0700000-0007-4b00-a000-000000000001", "Name": "OUT", "Description": "validation results", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script.",
      "Code": "import clr\nclr.AddReference('RevitAPI')\nclr.AddReference('RevitServices')\nclr.AddReference('ProtoGeometry')\nfrom Autodesk.Revit.DB import *\nfrom Autodesk.DesignScript.Geometry import Point as DSPoint\nfrom RevitServices.Persistence import DocumentManager\nimport json\nimport time\nfrom datetime import datetime\n\ndoc = DocumentManager.Instance.CurrentDBDocument\nstart = time.time()\n\nelements = IN[0] if isinstance(IN[0], list) else [IN[0]]\nwalls = IN[1] if isinstance(IN[1], list) else [IN[1]]\noffsets = IN[2] if isinstance(IN[2], list) else [IN[2]]\ntolerance = float(IN[3]) if IN[3] else 0.05\n\nresults = []\nstatuses = []\ndistances = []\n\nwall_elements = [UnwrapElement(w) for w in walls]\n\nfor i, elem in enumerate(elements):\n    try:\n        el = UnwrapElement(elem)\n        loc = el.Location\n        if not hasattr(loc, 'Point'):\n            results.append({\n                \"elementId\": el.Id.IntegerValue,\n                \"realDistance\": -1,\n                \"expectedOffset\": offsets[i] if i < len(offsets) else 0,\n                \"difference\": -1,\n                \"status\": \"SEM_LOCALIZACAO\"\n            })\n            statuses.append(\"SEM_LOCALIZACAO\")\n            distances.append(-1)\n            continue\n\n        pt = loc.Point\n        expected = offsets[i] if i < len(offsets) else 0\n\n        min_dist = float('inf')\n        closest_wall_id = None\n\n        for wall in wall_elements:\n            try:\n                wall_loc = wall.Location\n                if hasattr(wall_loc, 'Curve'):\n                    curve = wall_loc.Curve\n                    result = curve.Project(pt)\n                    if result is not None:\n                        dist = pt.DistanceTo(result.XYZPoint)\n                        dist_m = dist * 0.3048\n                        if dist_m < min_dist:\n                            min_dist = dist_m\n                            closest_wall_id = wall.Id.IntegerValue\n            except:\n                continue\n\n        if min_dist == float('inf'):\n            results.append({\n                \"elementId\": el.Id.IntegerValue,\n                \"realDistance\": -1,\n                \"expectedOffset\": expected,\n                \"difference\": -1,\n                \"status\": \"SEM_PAREDE\"\n            })\n            statuses.append(\"SEM_PAREDE\")\n            distances.append(-1)\n        else:\n            diff = abs(min_dist - expected)\n            if diff <= tolerance:\n                status = \"OK\"\n            else:\n                status = \"FORA_DO_OFFSET\"\n\n            results.append({\n                \"elementId\": el.Id.IntegerValue,\n                \"wallId\": closest_wall_id,\n                \"realDistance\": round(min_dist, 4),\n                \"expectedOffset\": expected,\n                \"difference\": round(diff, 4),\n                \"status\": status\n            })\n            statuses.append(status)\n            distances.append(round(min_dist, 4))\n    except Exception as e:\n        results.append({\n            \"elementId\": -1,\n            \"realDistance\": -1,\n            \"expectedOffset\": 0,\n            \"difference\": -1,\n            \"status\": \"ERRO: \" + str(e)\n        })\n        statuses.append(\"ERRO\")\n        distances.append(-1)\n\nend = time.time()\n\nok_count = sum(1 for r in results if r[\"status\"] == \"OK\")\nfail_count = sum(1 for r in results if r[\"status\"] == \"FORA_DO_OFFSET\")\nno_wall = sum(1 for r in results if r[\"status\"] == \"SEM_PAREDE\")\n\noutput = {\n    \"validated\": results,\n    \"summary\": {\n        \"total\": len(results),\n        \"ok\": ok_count,\n        \"foraDoOffset\": fail_count,\n        \"semParede\": no_wall,\n        \"erros\": len(results) - ok_count - fail_count - no_wall\n    },\n    \"tolerance\": tolerance,\n    \"timestamp\": datetime.utcnow().isoformat() + \"Z\",\n    \"executionTimeMs\": int((end - start) * 1000)\n}\n\nOUT = [json.dumps(output, indent=2), statuses, distances]",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
