    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "n0300000-0003-4a00-9000-000000000003",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        { "Id": "p0300000-0003-4c00-9000-000000000001", "Name": "jsonData", "Description": "jsonData", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p0300000-0003-4b00-9000-000000000001", "Name": "", "Description": "familyName", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0300000-0003-4b00-9000-000000000002", "Name": "", "Description": "typeName", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0300000-0003-4b00-9000-000000000003", "Name": "", "Description": "points", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0300000-0003-4b00-9000-000000000004", "Name": "", "Description": "levelNames", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0300000-0003-4b00-9000-000000000005", "Name": "", "Description": "vectors", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0300000-0003-4b00-9000-000000000006", "Name": "", "Description": "params", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Allows DesignScript code to be authored directly",
      "Code": "familyName = jsonData[\"familyName\"];\ntypeName = jsonData[\"typeName\"];\nptData = jsonData[\"locationPoints\"];\npoints = List.Map(ptData, Function(p) { return Autodesk.DesignScript.Geometry.Point.ByCoordinates(p[\"x\"], p[\"y\"], p[\"z\"]); });\nlevelNames = jsonData[\"levels\"];\nvecData = jsonData[\"orientationVectors\"];\nvectors = List.Map(vecData, Function(v) { return Autodesk.DesignScript.Geometry.Vector.ByCoordinates(v[\"x\"], v[\"y\"], v[\"z\"]); });\nparams = jsonData[\"parameters\"];"
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "n0400000-0004-4a00-9000-000000000004",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        { "Id": "p0400000-0004-4c00-9000-000000000001", "Name": "familyName", "Description": "familyName", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0400000-0004-4c00-9000-000000000002", "Name": "typeName", "Description": "typeName", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p0400000-0004-4b00-9000-000000000001", "Name": "", "Description": "familyType", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Allows DesignScript code to be authored directly",
      "Code": "allTypes = Revit.Elements.FamilyType.ByFamilyNameAndTypeName(familyName, typeName);\nfamilyType = allTypes;"
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "n0500000-0005-4a00-9000-000000000005",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        { "Id": "p0500000-0005-4c00-9000-000000000001", "Name": "levelNames", "Description": "levelNames", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
