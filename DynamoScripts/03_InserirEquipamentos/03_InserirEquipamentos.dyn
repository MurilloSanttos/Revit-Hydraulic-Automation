      ],
      "Replication": "Disabled",
      "Description": "Allows DesignScript code to be authored directly",
      "Code": "levels = List.Map(levelNames, Function(n) { return Revit.Elements.Level.ByName(n); });"
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "n0600000-0006-4a00-9000-000000000006",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        { "Id": "p0600000-0006-4c00-9000-000000000001", "Name": "familyType", "Description": "familyType", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0600000-0006-4c00-9000-000000000002", "Name": "points", "Description": "points", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0600000-0006-4c00-9000-000000000003", "Name": "levels", "Description": "levels", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p0600000-0006-4b00-9000-000000000001", "Name": "", "Description": "instances", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Allows DesignScript code to be authored directly",
      "Code": "instances = Revit.Elements.FamilyInstance.ByPointAndLevel(familyType, points, levels);"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Id": "n0700000-0007-4a00-9000-000000000007",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        { "Id": "p0700000-0007-4c00-9000-000000000001", "Name": "IN[0]", "Description": "instances", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0700000-0007-4c00-9000-000000000002", "Name": "IN[1]", "Description": "vectors", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p0700000-0007-4b00-9000-000000000001", "Name": "OUT", "Description": "rotated instances", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script.",
      "Code": "import clr\nclr.AddReference('RevitAPI')\nclr.AddReference('RevitServices')\nfrom Autodesk.Revit.DB import *\nfrom RevitServices.Persistence import DocumentManager\nfrom RevitServices.Transactions import TransactionManager\nimport math\n\ndoc = DocumentManager.Instance.CurrentDBDocument\ninstances = UnwrapElement(IN[0]) if isinstance(IN[0], list) else [UnwrapElement(IN[0])]\nvectors = IN[1] if isinstance(IN[1], list) else [IN[1]]\n\nresults = []\n\nTransactionManager.Instance.EnsureInTransaction(doc)\n\nfor i, inst in enumerate(instances):\n    try:\n        if i < len(vectors) and vectors[i] is not None:\n            vec = vectors[i]\n            vx = vec.X\n            vy = vec.Y\n            angle = math.atan2(vy, vx)\n            loc = inst.Location\n            if hasattr(loc, 'Point'):\n                pt = loc.Point\n                axis = Line.CreateBound(pt, XYZ(pt.X, pt.Y, pt.Z + 1))\n                ElementTransformUtils.RotateElement(doc, inst.Id, axis, angle)\n        results.append(inst)\n    except Exception as e:\n        results.append(str(e))\n\nTransactionManager.Instance.TransactionTaskDone()\n\nOUT = results",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "n0800000-0008-4a00-9000-000000000008",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        { "Id": "p0800000-0008-4c00-9000-000000000001", "Name": "instances", "Description": "instances", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0800000-0008-4c00-9000-000000000002", "Name": "params", "Description": "params", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p0800000-0008-4b00-9000-000000000001", "Name": "", "Description": "setResults", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Allows DesignScript code to be authored directly",
      "Code": "keys = Dictionary.Keys(params);\nvals = Dictionary.Values(params);\nsetResults = [Imperative]\n{\n    results = {};\n    for (inst in instances)\n    {\n        for (k in 0..List.Count(keys)-1)\n        {\n            inst.SetParameterByName(keys[k], vals[k]);\n        }\n        results = List.AddItemToEnd(inst, results);\n    }\n    return results;\n};"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Id": "n0900000-0009-4a00-9000-000000000009",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        { "Id": "p0900000-0009-4c00-9000-000000000001", "Name": "IN[0]", "Description": "instances", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0900000-0009-4c00-9000-000000000002", "Name": "IN[1]", "Description": "points", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p0900000-0009-4b00-9000-000000000001", "Name": "OUT", "Description": "output JSON", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script.",
      "Code": "import clr\nimport json\nimport time\nfrom datetime import datetime\n\nstart = time.time()\ninstances = IN[0] if isinstance(IN[0], list) else [IN[0]]\npoints = IN[1] if isinstance(IN[1], list) else [IN[1]]\n\ncreated = []\nfailed = []\n\nfor i, inst in enumerate(instances):\n    try:\n        if isinstance(inst, str):\n            pt = points[i] if i < len(points) else None\n            failed.append({\n                \"index\": i,\n                \"point\": str(pt) if pt else \"unknown\",\n                \"error\": inst\n            })\n        else:\n            unwrapped = UnwrapElement(inst)\n            created.append({\n                \"index\": i,\n                \"elementId\": unwrapped.Id.IntegerValue\n            })\n    except Exception as e:\n        failed.append({\"index\": i, \"error\": str(e)})\n\nend = time.time()\n\nresult = {\n    \"success\": len(failed) == 0,\n    \"createdInstances\": [c[\"elementId\"] for c in created],\n    \"createdCount\": len(created),\n    \"failed\": failed,\n    \"failedCount\": len(failed),\n    \"timestamp\": datetime.utcnow().isoformat() + \"Z\",\n    \"executionTimeMs\": int((end - start) * 1000)\n}\n\nOUT = json.dumps(result, indent=2)",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "n1000000-0010-4a00-9000-000000000010",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        { "Id": "p1000000-0010-4c00-9000-000000000001", "Name": "instances", "Description": "instances", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p1000000-0010-4b00-9000-000000000001", "Name": "", "Description": "ids", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p1000000-0010-4b00-9000-000000000002", "Name": "", "Description": "names", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
