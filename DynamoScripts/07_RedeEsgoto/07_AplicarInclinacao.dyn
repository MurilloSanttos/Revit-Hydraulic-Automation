      ],
      "Replication": "Disabled",
      "Description": "Allows DesignScript code to be authored directly",
      "Code": "pipeIds = data[\"pipes\"];\nslopePercent = data[\"slopePercent\"];\nbaseZMode = data[\"baseZMode\"];\ntolerance = data[\"tolerance\"];\nsystemTypeId = data[\"systemTypeId\"];"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Id": "n0400000-0004-4a00-d000-000000000004",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        { "Id": "p0400000-0004-4c00-d000-000000000001", "Name": "IN[0]", "Description": "pipeIds", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0400000-0004-4c00-d000-000000000002", "Name": "IN[1]", "Description": "slopePercent", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0400000-0004-4c00-d000-000000000003", "Name": "IN[2]", "Description": "baseZMode", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0400000-0004-4c00-d000-000000000004", "Name": "IN[3]", "Description": "tolerance", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0400000-0004-4c00-d000-000000000005", "Name": "IN[4]", "Description": "systemTypeId", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p0400000-0004-4b00-d000-000000000001", "Name": "OUT", "Description": "results", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script.",
      "Code": "import clr\nclr.AddReference('RevitAPI')\nclr.AddReference('RevitServices')\nfrom Autodesk.Revit.DB import *\nfrom RevitServices.Persistence import DocumentManager\nfrom RevitServices.Transactions import TransactionManager\nimport json\nimport math\nimport time\nfrom datetime import datetime\n\nstart_time = time.time()\ndoc = DocumentManager.Instance.CurrentDBDocument\n\npipe_ids = IN[0] if isinstance(IN[0], list) else [IN[0]]\nslope_pct = float(IN[1])\nbase_z_mode = str(IN[2]).lower() if IN[2] else \"auto\"\ntol = float(IN[3]) if IN[3] else 0.005\nsys_type_id = int(IN[4]) if IN[4] else -1\n\nupdated_pipes = []\nslopes_applied = []\nfailed = []\nbefore_after = []\n\nTransactionManager.Instance.EnsureInTransaction(doc)\n\nfor pid in pipe_ids:\n    try:\n        eid = ElementId(int(pid))\n        pipe = doc.GetElement(eid)\n        if pipe is None:\n            failed.append({\"pipeId\": int(pid), \"error\": \"Element not found\"})\n            continue\n        \n        loc = pipe.Location\n        if not isinstance(loc, LocationCurve):\n            failed.append({\"pipeId\": int(pid), \"error\": \"No LocationCurve\"})\n            continue\n        \n        curve = loc.Curve\n        p1 = curve.GetEndPoint(0)\n        p2 = curve.GetEndPoint(1)\n        \n        dx = p2.X - p1.X\n        dy = p2.Y - p1.Y\n        horiz_dist = math.sqrt(dx*dx + dy*dy)\n        \n        if horiz_dist < 0.001:\n            failed.append({\"pipeId\": int(pid), \"error\": \"Vertical pipe, skip\"})\n            continue\n        \n        drop = horiz_dist * (slope_pct / 100.0)\n        \n        old_slope = abs(p1.Z - p2.Z) / horiz_dist * 100.0 if horiz_dist > 0 else 0\n        \n        if base_z_mode == \"start\":\n            new_z1 = p1.Z\n            new_z2 = p1.Z - drop\n        elif base_z_mode == \"end\":\n            new_z1 = p2.Z + drop\n            new_z2 = p2.Z\n        else:\n            if p1.Z >= p2.Z:\n                new_z1 = p1.Z\n                new_z2 = p1.Z - drop\n            else:\n                new_z1 = p2.Z + drop\n                new_z2 = p2.Z\n        \n        new_p1 = XYZ(p1.X, p1.Y, new_z1)\n        new_p2 = XYZ(p2.X, p2.Y, new_z2)\n        \n        new_line = Line.CreateBound(new_p1, new_p2)\n        loc.Curve = new_line\n        \n        slope_param = pipe.get_Parameter(BuiltInParameter.RBS_PIPE_SLOPE)\n        if slope_param and not slope_param.IsReadOnly:\n            slope_param.Set(slope_pct / 100.0)\n        \n        actual_dz = abs(new_z1 - new_z2)\n        actual_slope = (actual_dz / horiz_dist) * 100.0 if horiz_dist > 0 else 0\n        \n        updated_pipes.append(int(pid))\n        slopes_applied.append(round(actual_slope, 4))\n        \n        before_after.append({\n            \"pipeId\": int(pid),\n            \"oldSlope\": round(old_slope, 4),\n            \"newSlope\": round(actual_slope, 4),\n            \"drop_ft\": round(float(drop), 4),\n            \"horizDist_ft\": round(float(horiz_dist), 4),\n            \"startZ\": round(float(new_z1), 4),\n            \"endZ\": round(float(new_z2), 4)\n        })\n        \n    except Exception as e:\n        failed.append({\"pipeId\": int(pid) if pid else -1, \"error\": str(e)})\n\nall_ok = True\nslope_errors = []\nmin_slope = slope_pct * (1.0 - tol)\nfor i, sl in enumerate(slopes_applied):\n    if sl < min_slope:\n        all_ok = False\n        slope_errors.append({\n            \"pipeId\": updated_pipes[i],\n            \"appliedSlope\": sl,\n            \"minRequired\": round(min_slope, 4)\n        })\n\nTransactionManager.Instance.TransactionTaskDone()\n\nend_time = time.time()\navg_slope = sum(slopes_applied) / len(slopes_applied) if slopes_applied else 0\n\nif not all_ok:\n    status = \"ERRO_INCLINACAO\"\nelif len(failed) > 0 and len(updated_pipes) > 0:\n    status = \"PARCIAL\"\nelif len(failed) > 0 and len(updated_pipes) == 0:\n    status = \"FALHA_TOTAL\"\nelse:\n    status = \"OK\"\n\nresult = {\n    \"success\": status == \"OK\",\n    \"updatedPipes\": updated_pipes,\n    \"slopesApplied\": slopes_applied,\n    \"avgSlope\": round(avg_slope, 4),\n    \"targetSlope\": slope_pct,\n    \"baseZMode\": base_z_mode,\n    \"count\": len(updated_pipes),\n    \"failed\": failed,\n    \"failedCount\": len(failed),\n    \"slopeErrors\": slope_errors,\n    \"details\": before_after,\n    \"status\": status,\n    \"executionTimeMs\": int((end_time - start_time) * 1000),\n    \"timestamp\": datetime.utcnow().isoformat() + \"Z\"\n}\n\njson_str = json.dumps(result, indent=2)\nstatuses_list = []\nfor ba in before_after:\n    old = ba[\"oldSlope\"]\n    new = ba[\"newSlope\"]\n    if new >= min_slope:\n        statuses_list.append(\"OK\")\n    else:\n        statuses_list.append(\"ERRO\")\n\nOUT = [json_str, updated_pipes, slopes_applied, statuses_list, status, before_after]",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true
    },
