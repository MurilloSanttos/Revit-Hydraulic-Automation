      ],
      "Outputs": [
        { "Id": "p0300000-0003-4b00-d000-000000000001", "Name": "", "Description": "pipeIds", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0300000-0003-4b00-d000-000000000002", "Name": "", "Description": "slopePercent", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
