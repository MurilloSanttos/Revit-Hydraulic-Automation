    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Id": "n0500000-0005-4a00-c000-000000000005",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        { "Id": "p0500000-0005-4c00-c000-000000000001", "Name": "IN[0]", "Description": "fixPts", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0500000-0005-4c00-c000-000000000002", "Name": "IN[1]", "Description": "stackPt", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0500000-0005-4c00-c000-000000000003", "Name": "IN[2]", "Description": "fixtureIds", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0500000-0005-4c00-c000-000000000004", "Name": "IN[3]", "Description": "slopePercent", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0500000-0005-4c00-c000-000000000005", "Name": "IN[4]", "Description": "baseOffsetZ", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p0500000-0005-4b00-c000-000000000001", "Name": "OUT", "Description": "ordered segments with slope", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script.",
      "Code": "import clr\nclr.AddReference('ProtoGeometry')\nfrom Autodesk.DesignScript.Geometry import Point as DSPoint\nimport math\n\nfix_pts = IN[0] if isinstance(IN[0], list) else [IN[0]]\nstack_pt = IN[1]\nfix_ids = IN[2] if isinstance(IN[2], list) else [IN[2]]\nslope_pct = float(IN[3])\nbase_z = float(IN[4])\n\nsx = stack_pt.X\nsy = stack_pt.Y\n\npaired = []\nfor i, pt in enumerate(fix_pts):\n    try:\n        dx = pt.X - sx\n        dy = pt.Y - sy\n        dist = math.sqrt(dx*dx + dy*dy)\n        paired.append((i, pt, dist, fix_ids[i]))\n    except:\n        continue\n\npaired.sort(key=lambda x: x[2], reverse=True)\n\nstart_pts = []\nend_pts = []\nordered_ids = []\nslopes = []\ndrops = []\n\nstack_hz = DSPoint.ByCoordinates(sx, sy, base_z)\n\ncum_drop = 0.0\n\nfor idx, item in enumerate(paired):\n    pt = item[1]\n    fid = item[3]\n    \n    dx = pt.X - sx\n    dy = pt.Y - sy\n    dist_to_stack = math.sqrt(dx*dx + dy*dy)\n    \n    seg_drop = dist_to_stack * (slope_pct / 100.0)\n    \n    z_start = base_z + seg_drop\n    z_end = base_z + cum_drop\n    \n    sp = DSPoint.ByCoordinates(pt.X, pt.Y, z_start)\n    \n    if idx < len(paired) - 1:\n        nxt = paired[idx + 1]\n        npt = nxt[1]\n        dx2 = npt.X - sx\n        dy2 = npt.Y - sy\n        d2 = math.sqrt(dx2*dx2 + dy2*dy2)\n        z_end_seg = base_z + d2 * (slope_pct / 100.0)\n        ep = DSPoint.ByCoordinates(npt.X, npt.Y, z_end_seg)\n    else:\n        ep = DSPoint.ByCoordinates(sx, sy, base_z)\n    \n    start_pts.append(sp)\n    end_pts.append(ep)\n    ordered_ids.append(fid)\n    \n    dx_seg = ep.X - sp.X\n    dy_seg = ep.Y - sp.Y\n    seg_len = math.sqrt(dx_seg*dx_seg + dy_seg*dy_seg)\n    actual_drop = sp.Z - ep.Z\n    actual_slope = (actual_drop / seg_len * 100.0) if seg_len > 0 else 0\n    slopes.append(round(actual_slope, 3))\n    drops.append(round(actual_drop, 4))\n\nOUT = [start_pts, end_pts, ordered_ids, slopes, drops, stack_hz]",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "n0600000-0006-4a00-c000-000000000006",
