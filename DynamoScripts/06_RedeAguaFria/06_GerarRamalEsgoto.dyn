        { "Id": "p0600000-0006-4b00-c000-000000000002", "Name": "", "Description": "endPts", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0600000-0006-4b00-c000-000000000003", "Name": "", "Description": "orderedIds", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0600000-0006-4b00-c000-000000000004", "Name": "", "Description": "slopes", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0600000-0006-4b00-c000-000000000005", "Name": "", "Description": "drops", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0600000-0006-4b00-c000-000000000006", "Name": "", "Description": "stackHz", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Allows DesignScript code to be authored directly",
      "Code": "startPts = pyOut[0];\nendPts = pyOut[1];\norderedIds = pyOut[2];\nslopes = pyOut[3];\ndrops = pyOut[4];\nstackHz = pyOut[5];"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Id": "n0700000-0007-4a00-c000-000000000007",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        { "Id": "p0700000-0007-4c00-c000-000000000001", "Name": "IN[0]", "Description": "startPts", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0700000-0007-4c00-c000-000000000002", "Name": "IN[1]", "Description": "endPts", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0700000-0007-4c00-c000-000000000003", "Name": "IN[2]", "Description": "pipeTypeId", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0700000-0007-4c00-c000-000000000004", "Name": "IN[3]", "Description": "systemTypeId", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0700000-0007-4c00-c000-000000000005", "Name": "IN[4]", "Description": "diameter", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0700000-0007-4c00-c000-000000000006", "Name": "IN[5]", "Description": "orderedIds", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0700000-0007-4c00-c000-000000000007", "Name": "IN[6]", "Description": "slopes", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0700000-0007-4c00-c000-000000000008", "Name": "IN[7]", "Description": "slopePercent", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false },
        { "Id": "p0700000-0007-4c00-c000-000000000009", "Name": "IN[8]", "Description": "tolerance", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Outputs": [
        { "Id": "p0700000-0007-4b00-c000-000000000001", "Name": "OUT", "Description": "pipes and JSON", "UsingDefaultValue": false, "Level": 2, "UseLevels": false, "KeepListStructure": false }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script.",
      "Code": "import clr\nclr.AddReference('RevitAPI')\nclr.AddReference('RevitServices')\nfrom Autodesk.Revit.DB import *\nfrom Autodesk.Revit.DB.Plumbing import Pipe\nfrom RevitServices.Persistence import DocumentManager\nfrom RevitServices.Transactions import TransactionManager\nimport json\nimport time\nimport math\nfrom datetime import datetime\n\nstart_time = time.time()\ndoc = DocumentManager.Instance.CurrentDBDocument\n\nstart_pts = IN[0] if isinstance(IN[0], list) else [IN[0]]\nend_pts = IN[1] if isinstance(IN[1], list) else [IN[1]]\npipe_type_id = int(IN[2])\nsystem_type_id = int(IN[3])\ndiameter_mm = float(IN[4])\nordered_ids = IN[5] if isinstance(IN[5], list) else [IN[5]]\nslopes = IN[6] if isinstance(IN[6], list) else [IN[6]]\nslope_pct = float(IN[7])\ntolerance = float(IN[8]) if IN[8] else 0.01\n\ndiameter_ft = diameter_mm / 304.8\npipe_type_eid = ElementId(pipe_type_id)\nsystem_type_eid = ElementId(system_type_id)\n\nlevels = FilteredElementCollector(doc).OfClass(Level).ToElements()\nbase_level = levels[0] if levels else None\n\ncreated_pipes = []\nfailed = []\npipe_elements = []\nactual_slopes = []\n\nTransactionManager.Instance.EnsureInTransaction(doc)\n\nfor i in range(len(start_pts)):\n    try:\n        sp = start_pts[i]\n        ep = end_pts[i]\n        \n        p1 = XYZ(sp.X / 304.8, sp.Y / 304.8, sp.Z / 304.8)\n        p2 = XYZ(ep.X / 304.8, ep.Y / 304.8, ep.Z / 304.8)\n        \n        dist = p1.DistanceTo(p2)\n        if dist < 0.01:\n            failed.append({\"index\": i, \"fixtureId\": ordered_ids[i] if i < len(ordered_ids) else -1, \"error\": \"Points too close\"})\n            continue\n        \n        pipe = Pipe.Create(doc, system_type_eid, pipe_type_eid, base_level.Id, p1, p2)\n        \n        param_diam = pipe.get_Parameter(BuiltInParameter.RBS_PIPE_DIAMETER_PARAM)\n        if param_diam and not param_diam.IsReadOnly:\n            param_diam.Set(diameter_ft)\n        \n        param_slope = pipe.get_Parameter(BuiltInParameter.RBS_PIPE_SLOPE)\n        if param_slope and not param_slope.IsReadOnly:\n            param_slope.Set(slope_pct / 100.0)\n        \n        dz = abs(p1.Z - p2.Z)\n        dxy = math.sqrt((p2.X-p1.X)**2 + (p2.Y-p1.Y)**2)\n        actual_sl = (dz / dxy * 100.0) if dxy > 0 else 0\n        actual_slopes.append(round(actual_sl, 3))\n        \n        created_pipes.append(pipe.Id.IntegerValue)\n        pipe_elements.append(pipe)\n    except Exception as e:\n        failed.append({\"index\": i, \"fixtureId\": ordered_ids[i] if i < len(ordered_ids) else -1, \"error\": str(e)})\n\nconnectivity_ok = True\nfor i in range(len(pipe_elements) - 1):\n    try:\n        c1 = pipe_elements[i].ConnectorManager.Connectors\n        c2 = pipe_elements[i+1].ConnectorManager.Connectors\n        best_dist = float('inf')\n        best_pair = None\n        for conn1 in c1:\n            for conn2 in c2:\n                d = conn1.Origin.DistanceTo(conn2.Origin)\n                if d < best_dist:\n                    best_dist = d\n                    best_pair = (conn1, conn2)\n        if best_pair and best_dist < tolerance:\n            if not best_pair[0].IsConnected and not best_pair[1].IsConnected:\n                best_pair[0].ConnectTo(best_pair[1])\n        elif best_dist >= tolerance:\n            connectivity_ok = False\n    except:\n        connectivity_ok = False\n\nslope_ok = True\nmin_slope = slope_pct * 0.8\nfor sl in actual_slopes:\n    if sl < min_slope:\n        slope_ok = False\n        break\n\nTransactionManager.Instance.TransactionTaskDone()\n\nend_time = time.time()\navg_slope = sum(actual_slopes) / len(actual_slopes) if actual_slopes else 0\n\nif not connectivity_ok:\n    status = \"ERRO_CONECTIVIDADE\"\nelif not slope_ok:\n    status = \"ERRO_INCLINACAO\"\nelif len(failed) > 0:\n    status = \"ERRO_PARCIAL\"\nelse:\n    status = \"OK\"\n\nresult = {\n    \"success\": status == \"OK\",\n    \"createdPipes\": created_pipes,\n    \"count\": len(created_pipes),\n    \"failed\": failed,\n    \"failedCount\": len(failed),\n    \"avgSlope\": round(avg_slope, 3),\n    \"targetSlope\": slope_pct,\n    \"slopesPerSegment\": actual_slopes,\n    \"connectivityValid\": connectivity_ok,\n    \"slopeValid\": slope_ok,\n    \"status\": status,\n    \"diameter_mm\": diameter_mm,\n    \"fixtureOrder\": ordered_ids,\n    \"executionTimeMs\": int((end_time - start_time) * 1000),\n    \"timestamp\": datetime.utcnow().isoformat() + \"Z\"\n}\n\nOUT = [json.dumps(result, indent=2), created_pipes, status, actual_slopes]",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true
    },
