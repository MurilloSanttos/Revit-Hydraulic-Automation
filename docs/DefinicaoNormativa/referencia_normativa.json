  "regras_logicas": {
    "vazao": [
      {
        "id": "RL-VZ-01",
        "nome": "Vazão provável",
        "condicao": "soma_pesos > 0 AND num_aparelhos > 1",
        "formula": "Q = 0.30 * sqrt(soma_pesos)",
        "unidade_saida": "L/s"
      },
      {
        "id": "RL-VZ-02",
        "nome": "Vazão mínima aparelho isolado",
        "condicao": "num_aparelhos == 1",
        "formula": "Q = MAX(Q_calculado, vazao_min_aparelho)",
        "unidade_saida": "L/s"
      },
      {
        "id": "RL-VZ-03",
        "nome": "Vazão com válvula de descarga",
        "condicao": "trecho_contem_valvula_descarga == true",
        "formula": "Q = 1.70 + 0.30 * sqrt(soma_pesos_demais)",
        "unidade_saida": "L/s"
      }
    ],

    "diametro_af": [
      {
        "id": "RL-DN-01",
        "nome": "Selecionar DN por velocidade",
        "condicao": "para cada DN comercial",
        "formula": "V = (Q / 1000) / (PI * (D_int/2000)^2)",
        "criterio": "V <= 3.0 m/s",
        "acao": "selecionar menor DN que atenda"
      },
      {
        "id": "RL-DN-02",
        "nome": "DN mínimo do aparelho",
        "condicao": "DN_calculado < DN_min_aparelho",
        "acao": "DN = DN_min_aparelho"
      },
      {
        "id": "RL-DN-03",
        "nome": "DN não aumenta para jusante (AF)",
        "condicao": "DN_jusante > DN_montante",
        "acao": "alerta_medio"
      }
    ],

    "perda_carga": [
      {
        "id": "RL-PC-01",
        "nome": "Perda de carga unitária FWH",
        "formula": "J = 8.69e6 * Q^1.75 / D_int^4.75",
        "unidade_saida": "m/m"
      },
      {
        "id": "RL-PC-02",
        "nome": "Perda no trecho",
        "formula": "DH = J * L * K",
        "variaveis": {
          "K": "1.20 (simplificado) ou 1.0 + soma_Leq/L (avançado)"
        }
      },
      {
        "id": "RL-PC-03",
        "nome": "Perda no caminho",
        "formula": "DH_caminho = SOMA(DH_trecho)"
      }
    ],

    "pressao": [
      {
        "id": "RL-PR-01",
