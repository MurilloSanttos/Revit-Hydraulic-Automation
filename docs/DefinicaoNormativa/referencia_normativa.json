    "metodo_dimensionamento": {
      "id": "probabilistico",
      "nome": "Método Probabilístico",
      "formula": "Q = C * sqrt(soma_pesos)",
      "coeficiente_C": 0.30,
      "aplicacao": "Instalações com até 400 aparelhos (residencial e comercial pequeno)",
      "excecoes": {
        "aparelho_isolado": "Usar vazão mínima de projeto do aparelho",
        "valvula_descarga": "Q = Q_vd + C * sqrt(soma_pesos_demais)"
      }
    },

    "pressao": {
      "minima_normativa_mca": 1.0,
      "minima_pratica_mca": 3.0,
